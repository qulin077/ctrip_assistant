# LLM: MiniMax OpenAI-compatible endpoint.
# Copy this file to .env, then fill MINIMAX_API_KEY.
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_REASONING_SPLIT=true

# Optional compatibility aliases. Leave empty unless you want to override MiniMax.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_TEMPERATURE=1.0

# Embedding:
# Recommended production-style local model for Chinese/multilingual policy RAG.
# Use `local_hash` only when dependencies/model files are not installed yet.
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-m3

# Optional. Enables web-search fallback when present.
TAVILY_API_KEY=
